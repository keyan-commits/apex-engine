# OpenAI slot via GitHub Models (free real GPT-4o-mini, 150 req/day).
# Generate a fine-grained PAT at https://github.com/settings/personal-access-tokens/new
# Account permissions → Models → Read-only
GITHUB_MODELS_TOKEN=

# Llama slot via Groq (free, 1000 req/day per model, no expiry).
# Hosts llama-3.3-70b-versatile and many other open models.
# Sign up at https://console.groq.com (email only, no card) → API Keys → Create.
GROQ_API_KEY=

# Google AI Studio Gemini (free daily quota on 2.5-flash and lower) — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# DeepSeek (optional 5th slot — reasoning-strong, very cheap).
# Pay-as-you-go: deepseek-chat is $0.14/M input + $0.28/M output as of
# 2026-05-24. NOT free, but a $1 credit covers thousands of fan-outs.
# Sign up at https://platform.deepseek.com → API Keys.
# Leave blank to disable the DeepSeek slot entirely — the fan-out will
# silently skip it, no error panel.
DEEPSEEK_API_KEY=

# Web search for grounding (Wave 17a). At least one of these is required
# for apex_web_search and Settings → "Web grounding" to work. Leave both
# blank to disable. Tavily is recommended — it's the only one with a
# no-credit-card free tier.
#
# Tavily — primary. LLM-optimized snippets (cleaner for prompt injection).
# Free tier: 1000 API credits/month, NO credit card required.
# Sign up: https://app.tavily.com → API Keys.
TAVILY_API_KEY=
#
# Brave Search — fallback (also usable as primary via provider="brave").
# Pricing as of 2026-05-24: $5/month of complimentary credit auto-applied
# at $5 per 1000 requests on the Search plan = ~1000 free queries/month.
# Credit card IS required at signup to receive the credit.
# Sign up: https://brave.com/search/api
BRAVE_API_KEY=

# Anthropic — NOT REQUIRED.
# Claude is called via @anthropic-ai/claude-agent-sdk, which reuses
# the Claude Code OAuth login on this machine. No API key needed.
