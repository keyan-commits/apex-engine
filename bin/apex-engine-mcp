#!/bin/sh
# apex-engine MCP server launcher.
# Invokes the TypeScript server via the project-local tsx loader so we don't
# need a build step. Sets cwd to the project root so SQLite data files land
# in apex-engine/data/ regardless of where Claude Code spawns this from.
# --env-file-if-exists loads provider API keys from .env.local (Next.js
# auto-loads this for pnpm dev; the MCP server runs outside Next so we
# load it here).
set -e
DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$DIR"
exec "$DIR/node_modules/.bin/tsx" --env-file-if-exists="$DIR/.env.local" "$DIR/src/mcp/server.ts" "$@"
